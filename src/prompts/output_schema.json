{
  "type": "object",
  "properties": {
    "code": {
      "anyOf": [{"type": "string", "pattern": "^\\d{10}$"}, {"type": "null"}],
      "description": "10-digit TN VED code as plain digits, or null if genuinely cannot determine even the 4-digit heading"
    },
    "name": {"type": "string", "description": "Short product name matching the code"},
    "justification": {"type": "string", "description": "1-3 sentences explaining why this code"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "next_question": {
      "anyOf": [{"type": "string"}, {"type": "null"}],
      "description": "Single plain-language question to ask the user, or null if the product can be classified without more info"
    },
    "alternative_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {"type": "string", "pattern": "^\\d{10}$"},
          "reason": {"type": "string"}
        },
        "required": ["code", "reason"],
        "additionalProperties": false
      },
      "maxItems": 3
    }
  },
  "required": ["code", "name", "justification", "confidence", "next_question", "alternative_codes"],
  "additionalProperties": false
}
